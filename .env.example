# ---- Supabase ----
# Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Server-only. NEVER expose to the client. Used for admin tasks (e.g. provisioning).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Hugging Face Inference API ----
# https://huggingface.co/settings/tokens  (free "read" token is enough)
HUGGINGFACE_API_KEY=hf_your_token

# ---- Email (Resend) — optional ----
# Enables auto-sending team-invite emails. Without it, invites still work via a
# copyable link shown in the UI. Create a key at https://resend.com (API Keys),
# and use a sender on a domain you've verified in Resend.
RESEND_API_KEY=re_your_key
EMAIL_FROM=yourATS <noreply@yourats.online>

# ---- App ----
# Used for building absolute URLs / redirects. No trailing slash.
NEXT_PUBLIC_APP_URL=http://localhost:3000
